UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenTelemetry -> public fleet OTLP/HTTP ingest (HTTP Basic auth, traefik-native).
# Endpoint omits the /v1/traces suffix; the exporter appends it.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.leonardoacosta.dev
# Authorization=Basic <base64("fleet-otlp:<password>")> -- real value in Vercel env, never here.
OTEL_EXPORTER_OTLP_HEADERS=
